<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-slate-100 text-slate-800 min-h-screen">
    <%- include('../layouts/topnav', { title, user, activePage }) %>

    <main class="max-w-7xl mx-auto px-4 py-6 space-y-5">
      <section class="bg-white rounded-xl shadow-sm p-4">
        <form method="GET" action="/muzakki" class="grid md:grid-cols-6 gap-3">
          <input name="search" value="<%= filters.search %>" placeholder="Cari nama" class="md:col-span-2 rounded-lg border border-slate-300 px-3 py-2" />

          <select name="rt_rw_id" class="rounded-lg border border-slate-300 px-3 py-2">
            <option value="">Semua RT/RW</option>
            <% rtRwList.forEach((item) => { %>
              <option value="<%= item.id %>" <%= filters.rt_rw_id === String(item.id) ? 'selected' : '' %>>RT <%= item.rt %> / RW <%= item.rw %></option>
            <% }) %>
          </select>

          <select name="jenis_zakat" class="rounded-lg border border-slate-300 px-3 py-2">
            <option value="">Semua Jenis</option>
            <option value="beras" <%= filters.jenis_zakat === 'beras' ? 'selected' : '' %>>Beras</option>
            <option value="uang" <%= filters.jenis_zakat === 'uang' ? 'selected' : '' %>>Uang</option>
          </select>

          <input type="date" name="date_from" value="<%= filters.date_from %>" class="rounded-lg border border-slate-300 px-3 py-2" />
          <input type="date" name="date_to" value="<%= filters.date_to %>" class="rounded-lg border border-slate-300 px-3 py-2" />

          <div class="md:col-span-6 flex gap-2 justify-end">
            <a href="/muzakki" class="px-4 py-2 rounded-lg border border-slate-300 text-sm">Reset</a>
            <button type="submit" class="px-4 py-2 rounded-lg bg-slate-800 text-white text-sm">Filter</button>
            <button type="button" id="openCreateModal" class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm">Tambah Muzakki</button>
          </div>
        </form>
      </section>

      <section class="bg-white rounded-xl shadow-sm">
        <div class="hidden md:block overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-slate-600">
            <tr>
              <th class="text-left px-4 py-3">Nama</th>
              <th class="text-left px-4 py-3">RT/RW</th>
              <th class="text-left px-4 py-3">Jiwa</th>
              <th class="text-left px-4 py-3">Jenis</th>
              <th class="text-left px-4 py-3">Pembayaran</th>
              <th class="text-left px-4 py-3">Tanggal</th>
              <th class="text-right px-4 py-3">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (muzakkiList.length === 0) { %>
              <tr>
                <td colspan="7" class="px-4 py-8 text-center text-slate-500">Belum ada data muzakki</td>
              </tr>
            <% } %>

            <% muzakkiList.forEach((item) => { %>
              <tr class="border-t border-slate-100">
                <td class="px-4 py-3"><%= item.nama %></td>
                <td class="px-4 py-3">RT <%= item.rt %> / RW <%= item.rw %></td>
                <td class="px-4 py-3"><%= item.jumlah_jiwa %></td>
                <td class="px-4 py-3 uppercase"><%= item.jenis_zakat %></td>
                <td class="px-4 py-3">
                  <% if (item.jenis_zakat === 'beras') { %>
                    <% const totalBeras = Number(item.jumlah_beras_kg || 0) + Number(item.sedekah_beras_kg || 0); %>
                    <div><%= totalBeras.toFixed(2) %> kg</div>
                    <div class="text-xs text-slate-500">
                      zakat <%= Number(item.jumlah_beras_kg || 0).toFixed(2) %> kg
                      <% if (Number(item.sedekah_beras_kg || 0) > 0) { %>
                        + sedekah <%= Number(item.sedekah_beras_kg || 0).toFixed(2) %> kg
                      <% } %>
                    </div>
                  <% } else { %>
                    <% const totalUang = Number(item.jumlah_uang || 0) + Number(item.sedekah_uang || 0); %>
                    <div>Rp <%= totalUang.toLocaleString('id-ID') %></div>
                    <div class="text-xs text-slate-500">
                      zakat Rp <%= Number(item.jumlah_uang || 0).toLocaleString('id-ID') %>
                      <% if (Number(item.sedekah_uang || 0) > 0) { %>
                        + sedekah Rp <%= Number(item.sedekah_uang || 0).toLocaleString('id-ID') %>
                      <% } %>
                    </div>
                  <% } %>
                </td>
                <td class="px-4 py-3"><%= String(item.tanggal_bayar).slice(0, 10) %></td>
                <td class="px-4 py-3 text-right">
                  <button type="button" class="editBtn text-blue-600 hover:text-blue-700 mr-3" data-item='<%- JSON.stringify(item) %>'>Edit</button>
                  <% if (user.role === 'admin') { %>
                    <button type="button" class="deleteBtn text-red-600 hover:text-red-700" data-id="<%= item.id %>">Hapus</button>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>

        <div class="md:hidden p-3 space-y-3">
          <% if (muzakkiList.length === 0) { %>
            <div class="rounded-lg border border-slate-200 p-4 text-sm text-slate-500 text-center">Belum ada data muzakki</div>
          <% } %>
          <% muzakkiList.forEach((item) => { %>
            <div class="rounded-lg border border-slate-200 p-3 space-y-2">
              <div class="flex items-center justify-between">
                <p class="font-semibold"><%= item.nama %></p>
                <p class="text-xs uppercase text-slate-500"><%= item.jenis_zakat %></p>
              </div>
              <p class="text-sm text-slate-600">RT/RW: RT <%= item.rt %> / RW <%= item.rw %></p>
              <p class="text-sm text-slate-600">Jiwa: <%= item.jumlah_jiwa %></p>
              <p class="text-sm text-slate-600">Tanggal: <%= String(item.tanggal_bayar).slice(0, 10) %></p>
              <div class="text-sm text-slate-700">
                <% if (item.jenis_zakat === 'beras') { %>
                  <% const totalBeras = Number(item.jumlah_beras_kg || 0) + Number(item.sedekah_beras_kg || 0); %>
                  <p>Total: <%= totalBeras.toFixed(2) %> kg</p>
                  <p class="text-xs text-slate-500">zakat <%= Number(item.jumlah_beras_kg || 0).toFixed(2) %> kg<% if (Number(item.sedekah_beras_kg || 0) > 0) { %> + sedekah <%= Number(item.sedekah_beras_kg || 0).toFixed(2) %> kg<% } %></p>
                <% } else { %>
                  <% const totalUang = Number(item.jumlah_uang || 0) + Number(item.sedekah_uang || 0); %>
                  <p>Total: Rp <%= totalUang.toLocaleString('id-ID') %></p>
                  <p class="text-xs text-slate-500">zakat Rp <%= Number(item.jumlah_uang || 0).toLocaleString('id-ID') %><% if (Number(item.sedekah_uang || 0) > 0) { %> + sedekah Rp <%= Number(item.sedekah_uang || 0).toLocaleString('id-ID') %><% } %></p>
                <% } %>
              </div>
              <div class="pt-1 flex gap-3 text-sm">
                <button type="button" class="editBtn text-blue-600" data-item='<%- JSON.stringify(item) %>'>Edit</button>
                <% if (user.role === 'admin') { %>
                  <button type="button" class="deleteBtn text-red-600" data-id="<%= item.id %>">Hapus</button>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    </main>

    <div id="modal" class="fixed inset-0 bg-black/40 hidden items-center justify-center p-4">
      <div class="bg-white w-full max-w-2xl rounded-xl p-5">
        <h2 id="modalTitle" class="text-lg font-semibold mb-4">Tambah Muzakki</h2>

        <form id="muzakkiForm" class="grid md:grid-cols-2 gap-3">
          <input type="hidden" id="muzakkiId" />

          <div class="md:col-span-2">
            <label class="text-sm">Nama</label>
            <input id="nama" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
          </div>

          <div>
            <label class="text-sm">RT/RW</label>
            <select id="rt_rw_id" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
              <option value="">Pilih RT/RW</option>
              <% rtRwList.forEach((item) => { %>
                <option value="<%= item.id %>">RT <%= item.rt %> / RW <%= item.rw %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="text-sm">Jumlah Jiwa</label>
            <input id="jumlah_jiwa" type="number" min="1" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
          </div>

          <div>
            <label class="text-sm">Jenis Zakat</label>
            <select id="jenis_zakat" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2">
              <option value="beras">Beras</option>
              <option value="uang">Uang</option>
            </select>
          </div>

          <div>
            <label class="text-sm">Tanggal Bayar</label>
            <input id="tanggal_bayar" type="date" required class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
          </div>

          <div id="pembayaran_beras_wrapper">
            <label class="text-sm">Total Dibayar Beras (kg)</label>
            <input
              id="jumlah_beras_kg"
              type="text"
              inputmode="decimal"
              placeholder="7kg"
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2"
            />
            <p class="text-xs text-slate-500 mt-1">Jika lebih dari nilai wajib, selisih dihitung sedekah.</p>
          </div>

          <div id="pembayaran_uang_wrapper">
            <label class="text-sm">Total Dibayar Uang</label>
            <input
              id="jumlah_uang"
              type="text"
              inputmode="numeric"
              placeholder="Rp50.000"
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2"
            />
            <p class="text-xs text-slate-500 mt-1">Jika lebih dari nilai wajib, selisih dihitung sedekah.</p>
          </div>

          <div class="md:col-span-2">
            <p id="info_perhitungan" class="text-xs rounded-lg bg-slate-50 border border-slate-200 px-3 py-2 text-slate-600"></p>
          </div>

          <div class="md:col-span-2">
            <label class="text-sm">Alamat Detail</label>
            <input id="alamat_detail" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
          </div>

          <div>
            <label class="text-sm">No HP</label>
            <input id="no_hp" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
          </div>

          <div>
            <label class="text-sm">Keterangan</label>
            <input id="keterangan" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2" />
          </div>

          <p id="formError" class="md:col-span-2 text-sm text-red-600 hidden"></p>

          <div class="md:col-span-2 flex justify-end gap-2 pt-2">
            <button type="button" id="closeModal" class="px-4 py-2 border border-slate-300 rounded-lg">Batal</button>
            <button type="submit" class="px-4 py-2 bg-emerald-600 text-white rounded-lg">Simpan</button>
          </div>
        </form>
      </div>
    </div>

    <script>
      window.SIZAKAT = {
        zakatPerJiwaKg: <%= Number(zakatPerJiwaKg || 3.5) %>,
        zakatPerJiwaUang: <%= Number(zakatPerJiwaUang || 50000) %>
      };
    </script>
    <script src="/js/muzakki-page.js"></script>
  </body>
</html>
