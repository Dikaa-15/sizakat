PORT=3000
NODE_ENV=development

# Database mode: mysql | supabase | postgres
DB_MODE=mysql

# MySQL (local/dev)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sizakat

# Supabase/Postgres (Railway production)
# You can set DATABASE_URL only, or use full SUPABASE_DB_* fields.
DATABASE_URL=
SUPABASE_DB_URL=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=
DB_SSL_DISABLE=false

# Supabase API client (optional for direct Supabase SDK usage)
SUPABASE_URL=
SUPABASE_ANON_KEY=

SEED_ADMIN_PASSWORD=admin123
JWT_SECRET=replace_with_secure_random_secret
JWT_EXPIRES_IN=8h
